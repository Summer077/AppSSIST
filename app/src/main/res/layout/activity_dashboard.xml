<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_container">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Header (Shared) -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="120dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/top_design"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/RoundedBottomCorners"
                    android:contentDescription="Top Design" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:layout_marginTop="5dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/assist"
                        android:contentDescription="ASSIST Logo" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ASSIST"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/lexend"
                        android:letterSpacing="0.05" />
                </LinearLayout>
            </FrameLayout>

            <!-- Home Content -->
            <LinearLayout
                android:id="@+id/layout_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="24dp"
                android:visibility="visible">

                <!-- Greeting -->
                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello!"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/lexend"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Create schedule easily with ASSIST."
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:fontFamily="@font/lexend"
                    android:layout_marginBottom="16dp" />

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:layout_marginBottom="16dp">

                    <!-- Total Staff Card -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:padding="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="65dp"
                                android:layout_height="65dp"
                                android:src="@drawable/total_staff"
                                android:scaleType="fitCenter" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Staff"
                                    android:textSize="10sp"
                                    android:textColor="#888888"
                                    android:fontFamily="@font/lexend" />

                                <TextView
                                    android:id="@+id/tv_total_staff"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="@font/lexend" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Total Sections Card -->
                    <FrameLayout
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:padding="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="65dp"
                                android:layout_height="65dp"
                                android:src="@drawable/total_section"
                                android:scaleType="fitCenter" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="4dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Sections"
                                    android:textSize="10sp"
                                    android:textColor="#888888"
                                    android:fontFamily="@font/lexend" />

                                <TextView
                                    android:id="@+id/tv_total_sections"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="24sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="@font/lexend" />
                            </LinearLayout>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <!-- Quick Actions -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="5"
                    android:layout_marginBottom="24dp">

                    <FrameLayout
                        android:id="@+id/btn_create_schedule"
                        android:layout_width="0dp"
                        android:layout_height="75dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="2dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/create_schedule"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Create Schedule"
                                android:textSize="7sp"
                                android:textAlignment="center"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/lexend"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btn_add_course"
                        android:layout_width="0dp"
                        android:layout_height="75dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="2dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/add_course"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Course"
                                android:textSize="7sp"
                                android:textAlignment="center"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/lexend"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btn_add_staff"
                        android:layout_width="0dp"
                        android:layout_height="75dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="2dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/add_staff"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Staff"
                                android:textSize="7sp"
                                android:textAlignment="center"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/lexend"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btn_add_section"
                        android:layout_width="0dp"
                        android:layout_height="75dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="2dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/add_section"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Section"
                                android:textSize="7sp"
                                android:textAlignment="center"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/lexend"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </FrameLayout>

                    <FrameLayout
                        android:id="@+id/btn_add_room"
                        android:layout_width="0dp"
                        android:layout_height="75dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="3dp"
                        android:background="@drawable/bg_neumorphic_button"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="2dp">
                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/add_room"
                                android:scaleType="fitCenter" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Room"
                                android:textSize="7sp"
                                android:textAlignment="center"
                                android:textColor="@color/text_primary"
                                android:fontFamily="@font/lexend"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Activity"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/lexend"
                    android:layout_marginBottom="12dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/lexend"
                            android:layout_marginBottom="10dp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_neumorphic_button"
                            android:layout_marginBottom="10dp"
                            android:padding="10dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ra_logo" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="You created a section named CPE32S1."
                                    android:textSize="11sp"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="@font/lexend"
                                    android:layout_marginStart="10dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="01/24/2026  6:25 AM"
                                    android:textSize="8sp"
                                    android:textColor="#888888"
                                    android:fontFamily="@font/lexend" />
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_neumorphic_button"
                            android:padding="10dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ra_logo" />
                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:layout_height="wrap_content"
                                    android:text="You created a section named CPE32S1."
                                    android:textSize="11sp"
                                    android:textColor="@color/text_primary"
                                    android:fontFamily="@font/lexend"
                                    android:layout_marginStart="10dp" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="01/24/2026  7:25 AM"
                                    android:textSize="8sp"
                                    android:textColor="#888888"
                                    android:fontFamily="@font/lexend" />
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>

            <!-- Course Content Placeholder -->
            <LinearLayout
                android:id="@+id/layout_course"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Course Page"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/lexend" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage your courses here."
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Schedule Content Placeholder -->
            <LinearLayout
                android:id="@+id/layout_schedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule Page"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/lexend" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View and create schedules."
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <!-- Profile Content Placeholder -->
            <LinearLayout
                android:id="@+id/layout_profile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:padding="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile Page"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/lexend" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manage your account settings."
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:fontFamily="@font/lexend"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:background="@drawable/bg_bottom_nav"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="12dp"
        android:paddingHorizontal="12dp"
        android:weightSum="100">

        <!-- Nav Dashboard (Home) -->
        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="40"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_active_nav"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_home"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/dashboard"
                app:tint="#1E2124" />
            <TextView
                android:id="@+id/tv_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1E2124"
                android:fontFamily="@font/lexend"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="visible" />
        </LinearLayout>

        <!-- Nav Course -->
        <LinearLayout
            android:id="@+id/nav_course"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="20"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_course"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/course"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/tv_course"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Course"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1E2124"
                android:fontFamily="@font/lexend"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Nav Schedule -->
        <LinearLayout
            android:id="@+id/nav_schedule"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="20"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_schedule"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/schedule"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/tv_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Schedule"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1E2124"
                android:fontFamily="@font/lexend"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Nav Profile -->
        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="20"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="10dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:id="@+id/iv_profile"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/profile"
                app:tint="#FFFFFF" />
            <TextView
                android:id="@+id/tv_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#1E2124"
                android:fontFamily="@font/lexend"
                android:layout_marginStart="6dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
