<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/nav_anchor">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Content Area -->
            <LinearLayout
                android:id="@+id/layout_home"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- Header Section -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_top_header"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/top_design"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/RoundedBottomCorners" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_gravity="center"
                        android:gravity="center"
                        android:layout_marginTop="5dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/assist"
                            android:contentDescription="ASSIST Logo" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ASSIST"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="@font/lexend"
                            android:letterSpacing="0.05" />
                    </LinearLayout>
                </FrameLayout>

                <!-- Staff Dashboard Section -->
                <include
                    android:id="@+id/ll_staff_dashboard_content"
                    layout="@layout/staff_dashboard"
                    android:visibility="gone" />

                <!-- Admin Dashboard Section -->
                <LinearLayout
                    android:id="@+id/ll_admin_dashboard_content"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="12dp"
                    android:visibility="visible">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello!"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/lexend"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_welcome_desc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Create schedule easily with ASSIST."
                        android:textSize="12sp"
                        android:textColor="#555555"
                        android:fontFamily="@font/lexend"
                        android:layout_marginBottom="16dp" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:id="@+id/ll_stats_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:layout_marginBottom="16dp">

                        <FrameLayout
                            android:id="@+id/card_total_staff"
                            android:layout_width="0dp"
                            android:layout_height="90dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_neumorphic_button"
                            android:padding="8dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="65dp"
                                    android:layout_height="65dp"
                                    android:src="@drawable/total_staff" />
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:layout_marginStart="4dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Total Staff"
                                        android:textSize="10sp"
                                        android:textColor="#888888"
                                        android:fontFamily="@font/lexend" />
                                    <TextView
                                        android:id="@+id/tv_total_staff"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary"
                                        android:fontFamily="@font/lexend" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>

                        <FrameLayout
                            android:id="@+id/card_total_sections"
                            android:layout_width="0dp"
                            android:layout_height="90dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_neumorphic_button"
                            android:padding="8dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="65dp"
                                    android:layout_height="65dp"
                                    android:src="@drawable/total_section" />
                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical"
                                    android:layout_marginStart="4dp">
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Total Sections"
                                        android:textSize="10sp"
                                        android:textColor="#888888"
                                        android:fontFamily="@font/lexend" />
                                    <TextView
                                        android:id="@+id/tv_total_sections"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="0"
                                        android:textSize="24sp"
                                        android:textStyle="bold"
                                        android:textColor="@color/text_primary"
                                        android:fontFamily="@font/lexend" />
                                </LinearLayout>
                            </LinearLayout>
                        </FrameLayout>
                    </LinearLayout>

                    <!-- Quick Actions Row -->
                    <LinearLayout
                        android:id="@+id/ll_quick_actions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="5"
                        android:layout_marginBottom="24dp">
                        <FrameLayout android:id="@+id/btn_create_schedule" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_neumorphic_button"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="2dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/create_schedule" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create Schedule" android:textSize="7sp" android:textAlignment="center" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginTop="2dp" /></LinearLayout></FrameLayout>
                        <FrameLayout android:id="@+id/btn_add_course" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_neumorphic_button"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="2dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/add_course" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Course" android:textSize="7sp" android:textAlignment="center" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginTop="2dp" /></LinearLayout></FrameLayout>
                        <FrameLayout android:id="@+id/btn_add_staff" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_neumorphic_button"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="2dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/add_staff" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Staff" android:textSize="7sp" android:textAlignment="center" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginTop="2dp" /></LinearLayout></FrameLayout>
                        <FrameLayout android:id="@+id/btn_add_section" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_neumorphic_button"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="2dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/add_section" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Section" android:textSize="7sp" android:textAlignment="center" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginTop="2dp" /></LinearLayout></FrameLayout>
                        <FrameLayout android:id="@+id/btn_add_room" android:layout_width="0dp" android:layout_height="75dp" android:layout_weight="1" android:layout_marginHorizontal="3dp" android:background="@drawable/bg_neumorphic_button"><LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:padding="2dp"><ImageView android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/add_room" /><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Add Room" android:textSize="7sp" android:textAlignment="center" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginTop="2dp" /></LinearLayout></FrameLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_recent_activity_header"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recent Activity"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/lexend" android:layout_marginBottom="12dp" />

                    <FrameLayout
                        android:id="@+id/fl_recent_activity_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neumorphic_recessed"
                        android:padding="12dp">
                        <LinearLayout android:id="@+id/ll_recent_activity_list_container" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                            <TextView android:id="@+id/tv_recent_activity_date_header" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Today" android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text_primary" android:fontFamily="@font/lexend" android:layout_marginBottom="10dp" android:visibility="gone" />
                            <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="180dp" android:fillViewport="true"><LinearLayout android:id="@+id/ll_recent_activity_list" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" /></androidx.core.widget.NestedScrollView>
                            <TextView android:id="@+id/tv_no_recent_activity" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="There is no recent activity today." android:textSize="12sp" android:textColor="#888888" android:fontFamily="@font/lexend" android:gravity="center" android:padding="20dp" />
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>

            </LinearLayout>

            <!-- Other Tabs Area -->
            <include android:id="@+id/layout_course" layout="@layout/activity_course" android:visibility="gone" />
            <include android:id="@+id/layout_schedule" layout="@layout/activity_schedule" android:visibility="gone" />
            <include android:id="@+id/layout_profile" layout="@layout/activity_profile" android:visibility="gone" />

            <!-- Staff Specific Tabs -->
            <include android:id="@+id/layout_staff_schedule" layout="@layout/staff_schedule" android:visibility="gone" />
            <include android:id="@+id/layout_staff_profile" layout="@layout/staff_profile" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Shared Navigation Layer -->
    <FrameLayout
        android:id="@+id/nav_anchor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Admin Navigation (4 items) -->
        <LinearLayout
            android:id="@+id/bottom_nav_container"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_bottom_nav"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="12dp"
            android:paddingHorizontal="10dp"
            android:weightSum="100"
            android:visibility="visible">

            <LinearLayout android:id="@+id/nav_home" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="55" android:orientation="horizontal" android:gravity="center" android:background="@drawable/bg_active_nav" android:paddingHorizontal="12dp" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/iv_home" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/dashboard" app:tint="#1E2124" />
                <TextView android:id="@+id/tv_home" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Home" android:textSize="12sp" android:textStyle="bold" android:textColor="#1E2124" android:fontFamily="@font/lexend" android:layout_marginStart="8dp" android:maxLines="1" android:ellipsize="end" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_course" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="15" android:orientation="horizontal" android:gravity="center" android:paddingHorizontal="12dp" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/iv_course" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/course" app:tint="#FFFFFF" />
                <TextView android:id="@+id/tv_course" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Course" android:textSize="12sp" android:textStyle="bold" android:textColor="#1E2124" android:fontFamily="@font/lexend" android:layout_marginStart="8dp" android:maxLines="1" android:ellipsize="end" android:visibility="gone" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_schedule" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="15" android:orientation="horizontal" android:gravity="center" android:paddingHorizontal="12dp" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/iv_schedule" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/schedule" app:tint="#FFFFFF" />
                <TextView android:id="@+id/tv_schedule" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Schedule" android:textSize="12sp" android:textStyle="bold" android:textColor="#1E2124" android:fontFamily="@font/lexend" android:layout_marginStart="8dp" android:maxLines="1" android:ellipsize="end" android:visibility="gone" />
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_profile" android:layout_width="0dp" android:layout_height="42dp" android:layout_weight="15" android:orientation="horizontal" android:gravity="center" android:paddingHorizontal="12dp" android:clickable="true" android:focusable="true">
                <ImageView android:id="@+id/iv_profile" android:layout_width="22dp" android:layout_height="22dp" android:src="@drawable/profile" app:tint="#FFFFFF" />
                <TextView android:id="@+id/tv_profile" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" android:textSize="12sp" android:textStyle="bold" android:textColor="#1E2124" android:fontFamily="@font/lexend" android:layout_marginStart="8dp" android:maxLines="1" android:ellipsize="end" android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Staff Navigation (3 items) -->
        <include
            android:id="@+id/staff_nav_include"
            layout="@layout/staff_nav"
            android:visibility="gone" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
