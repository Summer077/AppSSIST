<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E9ECEF"
    android:fillViewport="true"
    android:visibility="gone">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header Background Section -->
        <RelativeLayout
            android:id="@+id/rl_profile_header"
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/iv_profile_bg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/profile_bg"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Profile Background" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000"
                android:clickable="false" />

            <!-- Profile Title & Edit Button -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="20dp"
                android:paddingTop="60dp"
                android:paddingBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Profile"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_edit_profile"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:scaleType="fitCenter"
                    android:src="@drawable/edit_profile" />
            </RelativeLayout>

            <!-- Profile Picture & Info -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_profile_pic"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:elevation="0dp"
                    app:cardCornerRadius="70dp"
                    app:cardElevation="0dp"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/iv_profile_pic"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/lexend"
                    android:text="Jennifer Enriquez"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_email_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="jenriquez@cpe.edu.ph"
                    android:textColor="#CCCCCC"
                    android:textSize="14sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Form Card Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/rl_profile_header"
            android:layout_marginTop="-30dp"
            android:orientation="vertical"
            android:background="@drawable/bg_bottom_nav"
            android:backgroundTint="#E7EBF0"
            android:elevation="4dp"
            android:paddingTop="30dp"
            android:paddingBottom="40dp"
            android:minHeight="600dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- Personal Information Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Personal Information"
                    android:textColor="#1E2124"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp"/>

                <!-- First Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="First Name"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/et_first_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:enabled="false"
                    android:fontFamily="@font/lexend"
                    android:paddingHorizontal="16dp"
                    android:text="Jennifer"
                    android:textColor="#212529"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Last Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Last Name"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/et_last_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:enabled="false"
                    android:fontFamily="@font/lexend"
                    android:paddingHorizontal="16dp"
                    android:text="Enriquez"
                    android:textColor="#212529"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <!-- Email (Read-only) -->
                <TextView
                    android:id="@+id/tv_email_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Email (Read-only)"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:fontFamily="@font/lexend"
                        android:paddingHorizontal="16dp"
                        android:text="jenriquez@cpe.edu.ph"
                        android:textColor="#888888"
                        android:textSize="14sp" />
                </RelativeLayout>

                <!-- Gender -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="gender"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="2dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_gender"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:paddingStart="10dp"
                        android:paddingEnd="30dp"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:enabled="false" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/text_primary"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Password"
                    android:textColor="#888888"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/et_password"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:enabled="false"
                        android:fontFamily="@font/lexend"
                        android:inputType="textPassword"
                        android:paddingHorizontal="16dp"
                        android:hint="Password"
                        android:textColor="#212529"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/iv_show_password"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="16dp"
                        android:src="@drawable/see"
                        app:tint="#888888"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <!-- Employment Status -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="employment status"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="2dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="32dp">

                    <Spinner
                        android:id="@+id/spinner_employment_status"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:paddingStart="10dp"
                        android:paddingEnd="30dp"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:enabled="false" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/text_primary"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <!-- Educational Attainment Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="Educational Attainment"
                    android:textColor="#1E2124"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="20dp" />

                <!-- Highest Degree -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="highest degree earned"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="2dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_degree"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:paddingStart="10dp"
                        android:paddingEnd="30dp"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:enabled="false" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/text_primary"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <!-- Specialization -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="specialization"
                    android:textColor="#888888"
                    android:textSize="9sp"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="2dp" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_neumorphic_recessed"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/spinner_specialization"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:spinnerMode="dropdown"
                        android:paddingStart="10dp"
                        android:paddingEnd="30dp"
                        android:overlapAnchor="false"
                        android:popupBackground="@drawable/bg_spinner_popup"
                        android:enabled="false" />

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="12dp"
                        android:src="@android:drawable/arrow_down_float"
                        app:tint="@color/text_primary"
                        android:importantForAccessibility="no" />
                </FrameLayout>

                <!-- PRC License Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/lexend"
                    android:text="PRC License:"
                    android:textColor="#333333"
                    android:textSize="18sp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="40dp">

                    <CheckBox
                        android:id="@+id/cb_qualified"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/lexend"
                        android:text="Qualified"
                        android:textColor="#333333"
                        android:textSize="18sp"
                        android:button="@drawable/bg_checkbox_neumorphic"
                        android:buttonTint="@null"
                        android:paddingStart="12dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:clickable="false"
                        android:focusable="false"/>

                    <CheckBox
                        android:id="@+id/cb_na"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="32dp"
                        android:fontFamily="@font/lexend"
                        android:text="NA"
                        android:textColor="#333333"
                        android:textSize="18sp"
                        android:button="@drawable/bg_checkbox_neumorphic"
                        android:buttonTint="@null"
                        android:paddingStart="12dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:clickable="false"
                        android:focusable="false"/>
                </LinearLayout>

                <!-- Edit Action Buttons -->
                <LinearLayout
                    android:id="@+id/ll_edit_actions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:layout_marginBottom="24dp">

                    <Button
                        android:id="@+id/btn_cancel_edit"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="#6C757D"
                        android:text="Cancel"
                        android:textAllCaps="false"
                        android:fontFamily="@font/lexend" />

                    <Button
                        android:id="@+id/btn_save_profile"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#1E2124"
                        android:text="Save"
                        android:textAllCaps="false"
                        android:fontFamily="@font/lexend" />
                </LinearLayout>

                <!-- Logout Button -->
                <Button
                    android:id="@+id/btn_logout"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:backgroundTint="#DC3545"
                    android:text="Logout"
                    android:textAllCaps="false"
                    android:fontFamily="@font/lexend"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="40dp"/>

            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</ScrollView>
