<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray"
    android:paddingHorizontal="32dp">

    <!-- ASSIST Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/assist"
        android:contentDescription="@string/app_logo"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp" />

    <!-- Welcome Text -->
    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome To ASSIST!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="@font/lexend"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@+id/logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Username Field -->
    <FrameLayout
        android:id="@+id/fl_username"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/bg_neumorphic_recessed"
        app:layout_constraintTop_toBottomOf="@+id/tv_welcome"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Username"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="#888888"
                android:fontFamily="@font/lexend"
                android:background="@null"
                android:inputType="text"
                android:paddingEnd="32dp"
                android:imeOptions="actionNext" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/user"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:tint="@color/text_primary"
                android:contentDescription="User icon" />
        </RelativeLayout>
    </FrameLayout>

    <!-- Password Field -->
    <FrameLayout
        android:id="@+id/fl_password"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_neumorphic_recessed"
        app:layout_constraintTop_toBottomOf="@+id/fl_username"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Password"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textColorHint="#888888"
                android:fontFamily="@font/lexend"
                android:background="@null"
                android:inputType="textPassword"
                android:paddingEnd="32dp"
                android:imeOptions="actionDone" />

            <ImageView
                android:id="@+id/iv_password_toggle"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/see"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:tint="@color/text_primary"
                android:contentDescription="Toggle password visibility" />
        </RelativeLayout>
    </FrameLayout>

    <!-- Remember Me + Forgot Password Row -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/row_options"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@+id/fl_password"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Separate View for Neumorphic Background -->
        <View
            android:id="@+id/v_cb_background"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@drawable/bg_checkbox_recessed"
            app:layout_constraintTop_toTopOf="@+id/cb_remember"
            app:layout_constraintBottom_toBottomOf="@+id/cb_remember"
            app:layout_constraintStart_toStartOf="parent" />

        <CheckBox
            android:id="@+id/cb_remember"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remember me?"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/lexend"
            android:button="@drawable/ic_checkbox_check"
            android:background="@null"
            android:paddingStart="10dp"
            android:minHeight="22dp"
            android:minWidth="22dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tv_forgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/lexend"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Login Button -->
    <FrameLayout
        android:id="@+id/btn_login"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_neumorphic_button"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toBottomOf="@+id/row_options"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Login"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/lexend" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
