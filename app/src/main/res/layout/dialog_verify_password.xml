<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@drawable/bg_neumorphic_popup"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify Identity"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1E2124"
        android:fontFamily="@font/lexend"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please enter your password to change your email address."
        android:textSize="14sp"
        android:textColor="#666666"
        android:fontFamily="@font/lexend"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/bg_neumorphic_recessed"
        android:layout_marginBottom="32dp">

        <EditText
            android:id="@+id/et_verify_password"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent"
            android:fontFamily="@font/lexend"
            android:hint="Password"
            android:inputType="textPassword"
            android:paddingStart="20dp"
            android:paddingEnd="54dp"
            android:textColor="#212529"
            android:textSize="15sp"
            android:importantForAutofill="no" />

        <ImageView
            android:id="@+id/iv_password_toggle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:src="@android:drawable/ic_partial_secure"
            app:tint="#AAAAAA"
            android:alpha="0.6"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            app:backgroundTint="#6C757D"
            android:text="Cancel"
            android:textAllCaps="false"
            android:fontFamily="@font/lexend"
            android:textSize="15sp"
            app:cornerRadius="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_verify"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            app:backgroundTint="#1E2124"
            android:text="Verify"
            android:textAllCaps="false"
            android:fontFamily="@font/lexend"
            android:textSize="15sp"
            app:cornerRadius="28dp" />
    </LinearLayout>

</LinearLayout>
