<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Background to maintain footprint -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/background_gray" />
        </shape>
    </item>

    <!-- Recessed Effect Container (inset to match the body of the raised button) -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <layer-list>
            <!-- Top-Left Shadow (Inner) -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#D1D9E6" />
                </shape>
            </item>
            <!-- Bottom-Right Highlight (Inner) -->
            <item android:left="2.5dp" android:top="2.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E9ECEF" />
                </shape>
            </item>
            <!-- Fill -->
            <item android:left="2.5dp" android:top="2.5dp" android:right="2.5dp" android:bottom="2.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E7EBF0" />
                </shape>
            </item>
        </layer-list>
    </item>
</layer-list>