<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <layer-list>
            <!-- Fixed size container to match the background view -->
            <item android:width="22dp" android:height="22dp">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <!-- The actual check tick -->
            <item android:width="16dp" android:height="16dp" android:gravity="center" android:drawable="@drawable/ic_check_tick" />
        </layer-list>
    </item>
    <item>
        <!-- Unchecked state: empty container -->
        <shape android:shape="rectangle">
            <size android:width="22dp" android:height="22dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>