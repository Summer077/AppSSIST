<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-Right Inner Light -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#E9ECEF" />
        </shape>
    </item>

    <!-- Top-Left Inner Dark -->
    <item
        android:right="2.5dp"
        android:bottom="2.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#D1D9E6" />
        </shape>
    </item>

    <!-- Fill -->
    <item
        android:left="2.5dp"
        android:top="2.5dp"
        android:right="2.5dp"
        android:bottom="2.5dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="#E7EBF0" />
        </shape>
    </item>
</layer-list>