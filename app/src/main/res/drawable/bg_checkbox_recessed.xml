<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Inner Shadow (Simulated) -->
    <!-- Light shadow Bottom-Right -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Dark shadow Top-Left -->
    <item
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#D1D9E6" />
        </shape>
    </item>

    <!-- Fill -->
    <item
        android:left="2dp"
        android:top="2dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="#E7EBF0" />
        </shape>
    </item>
</layer-list>