<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E9ECEF" />
                </shape>
            </item>
            <item android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#D1D9E6" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="1dp" android:bottom="1dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E7EBF0" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal State -->
    <item>
        <layer-list>
            <!-- Top-Left Highlight (Very Subtle) -->
            <item android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#F5F7FA" />
                </shape>
            </item>
            <!-- Bottom-Right Shadow (Subtle) -->
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#D1D9E6" />
                </shape>
            </item>
            <!-- Main Button Body -->
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E9ECEF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>