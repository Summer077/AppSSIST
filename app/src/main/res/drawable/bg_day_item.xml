<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state (Recessed - Curriculum Style) -->
    <item android:state_selected="true">
        <layer-list xmlns:android="http://schemas.android.com/apk/res/android">
            <!-- Bottom-Right Inner Light -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E9ECEF" />
                </shape>
            </item>
            <!-- Top-Left Inner Dark -->
            <item android:right="2.5dp" android:bottom="2.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#D1D9E6" />
                </shape>
            </item>
            <!-- Fill -->
            <item android:left="2.5dp" android:top="2.5dp" android:right="2.5dp" android:bottom="2.5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E7EBF0" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Normal state (Raised - Login Button Style) -->
    <item>
        <layer-list xmlns:android="http://schemas.android.com/apk/res/android">
            <item android:right="3dp" android:bottom="3dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#F5F7FA" />
                </shape>
            </item>
            <item android:left="4dp" android:top="4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#D1D9E6" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <solid android:color="#E9ECEF" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>