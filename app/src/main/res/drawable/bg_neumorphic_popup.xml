<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Bottom-right shadow (Dark) -->
    <item android:left="2dp" android:top="2dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#D1D9E6" />
        </shape>
    </item>

    <!-- Top-left shadow (Light/White) -->
    <item android:right="2dp" android:bottom="2dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#FFFFFF" />
        </shape>
    </item>

    <!-- Main Background -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape>
            <corners android:radius="16dp" />
            <solid android:color="#F0F2F5" />
        </shape>
    </item>
</layer-list>